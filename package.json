{
  "name": "bank-tests",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test tests/ui",
    "test:api": "npx playwright test tests/api",
    "test:sec": "npx playwright test tests/security",
    "test:sec:report": "npx playwright test tests/security && npm run allure:generate",
    "test:sec:fuzzing": "npx playwright test tests/security/fuzzing",
    "test:sec:input-attack": "npx playwright test tests/security/input-attack",
    "test:sec:ci": "npx playwright test tests/security/ci",
    "test:sec:regression": "npx playwright test tests/security/ci/security-regression.spec.ts",
    "test:sec:audit": "npx playwright test tests/security/ci/scan-results-audit.spec.ts",
    "discover:selectors": "npx ts-node scripts/check-login-selectors.ts",
    "allure:generate": "npx allure generate \"./allure-results\" -o \"./allure-report\"",
    "allure:open": "npx allure open allure-report",
    "allure:serve": "npx allure serve allure-results",
    "report:playwright": "npx playwright show-report --port 52330",
    "report:allure": "npx allure open allure-report --port 52331"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.9.0",
    "ajv": "^8.17.1",
    "allure-playwright": "^3.4.1",
    "dotenv": "^17.4.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "ajv-formats": "^3.0.1",
    "genson-js": "^0.0.8"
  }
}
